<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.QuizFragment">

    <ImageView
        android:id="@+id/imageView1"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitXY"
        android:rotation="180"
        android:src="@drawable/onda"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/imageView2"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="fitXY"
        android:src="@drawable/onda"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvCloseQuiz"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginTop="50dp"
        android:layout_marginRight="10dp"
        app:cardBackgroundColor="@color/grayCard"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/homeBtn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="5dp"
            android:src="@drawable/home"
            app:tint="@color/f1Red" />
    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/quizProgressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="100dp"
        android:progressDrawable="@drawable/vertical_progress_bar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:progress="50" />

    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="70dp"
        android:fontFamily="@font/foneregular"
        android:text="15"
        android:textColor="@color/f1Red"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvQuestion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="30dp"
        android:fontFamily="@font/unageo"
        android:gravity="center"
        android:text="@string/loading_question"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@+id/optionsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/quizProgressBar"
        app:layout_constraintTop_toBottomOf="@id/tvTimer" />

    <LinearLayout
        android:id="@+id/optionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvQuestion"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/quizProgressBar">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpt1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="A"
            android:layout_marginVertical="4dp"
            android:fontFamily="@font/unageo"
            android:textColor="@color/f1Black"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/grayCard"
            app:strokeWidth="3dp"
            android:textAllCaps="false"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpt2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="B"
            android:layout_marginVertical="4dp"
            android:fontFamily="@font/unageo"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/grayCard"
            app:strokeWidth="3dp"
            android:textAllCaps="false"
            android:textColor="@color/f1Black" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpt3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="C"
            android:layout_marginVertical="4dp"
            android:fontFamily="@font/unageo"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/grayCard"
            app:strokeWidth="3dp"
            android:textAllCaps="false"
            android:textColor="@color/f1Black"  />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpt4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="D"
            android:layout_marginVertical="4dp"
            android:fontFamily="@font/unageo"
            app:cornerRadius="8dp"
            android:backgroundTint="@color/grayCard"
            app:strokeWidth="3dp"
            android:textAllCaps="false"
            android:textColor="@color/f1Black"  />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>