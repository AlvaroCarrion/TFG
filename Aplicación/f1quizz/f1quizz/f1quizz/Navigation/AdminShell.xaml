<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="PPQ.Navigation.AdminShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:PPQ.Views.AdminShell"
    Title="PPQ">

    <ShellContent
        Title="{DynamicResource TitleLabelMenu}"
        ContentTemplate="{DataTemplate local:AdminMenuPage}"
        Icon="home_icon.png"
        Route="AdminMenuPage" />

    <FlyoutItem
        Title="{DynamicResource TitleLabelUsersAdministration}" 
        Icon="users_icon.png">
        
        <ShellContent
            Title="{DynamicResource TitleLabelUserList}"
            ContentTemplate="{DataTemplate local:UserListPage}"
            Icon="list_icon.png"
            Route="UserListPage" />

        <ShellContent
            Title="{DynamicResource TitleLabelCreateUsers}"
            ContentTemplate="{DataTemplate local:CreateUsersPage}"
            Icon="createusers_icon.png"
            Route="CreateUsersPage" />
        
        <ShellContent
            Title="{DynamicResource TitleLabelEditUsers}"
            ContentTemplate="{DataTemplate local:EditUsersPage}"
            Icon="pencil_icon.png"
            Route="EditUsersPage" />
    </FlyoutItem>
</Shell>