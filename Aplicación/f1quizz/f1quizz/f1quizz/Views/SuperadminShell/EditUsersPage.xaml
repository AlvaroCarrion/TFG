<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPQ.Views.SuperadminShell.EditUsersPage"
             Title="EditUsersPage">

    <Shell.TitleView>
        <StackLayout>
            <Label
                Style="{StaticResource LabelShellTitleStyle}"
                Text="{DynamicResource ShellLabelPolePositionQuiz}"/>
        </StackLayout>
    </Shell.TitleView>

    <VerticalStackLayout
        VerticalOptions="Fill">

        <Grid
            RowDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*"
            ColumnDefinitions="*,*,*">

            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource TitleLabelEditUsers}"
                Grid.Row="0"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelSubitleStyle}"
                Text="{DynamicResource LabelEditUsers}"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"/>

            <Entry
                x:Name="userEmail"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelMail}"
                Grid.Row="2"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="3"
                Grid.Column="1"/>

            <Entry
                x:Name="username"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelUser}"
                Grid.Row="4"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="5"
                Grid.Column="1"/>

            <Picker
                x:Name="rolPicker"
                SelectedIndexChanged="RolPicker"
                BackgroundColor="{DynamicResource ColorSecundary}"
                FontFamily="{DynamicResource FontUnageo}"
                FontSize="{DynamicResource LabelRegularSize}"
                TextColor="{DynamicResource ColorEntryText}"
                MinimumHeightRequest = "50"
                MaximumHeightRequest = "50"
                MinimumWidthRequest = "400"
                MaximumWidthRequest = "400"
                Grid.Row="6"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="7"
                Grid.Column="1"/>

            <Entry
                x:Name="password"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelPasswordNew}"
                IsPassword="True"
                Grid.Row="8"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="9"
                Grid.Column="1"/>

            <Entry
                x:Name="password2"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelConfirmPassword}"
                IsPassword="True"
                Grid.Row="10"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="11"
                Grid.Column="1"/>

            <Button Style="{StaticResource ButtonStyle}"
                Text="{DynamicResource ButtonLabelEditUser}"
                Clicked="EditUser"
                Grid.Row="12"
                Grid.Column="1"/>
        </Grid>
    </VerticalStackLayout>
</ContentPage>