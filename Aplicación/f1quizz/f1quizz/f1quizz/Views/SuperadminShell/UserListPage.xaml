<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPQ.Views.SuperadminShell.UserListPage"
             Title="UserListPage">
    
    <Shell.TitleView>
        <StackLayout>
            <Label
                Style="{StaticResource LabelShellTitleStyle}"
                Text="{DynamicResource ShellLabelPolePositionQuiz}"/>
        </StackLayout>
    </Shell.TitleView>

    <ScrollView
        VerticalOptions="Fill">

        <VerticalStackLayout>

        <Grid
            RowDefinitions="*,*,*,*,*"
            ColumnDefinitions="1*,8*,1*">

            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource TitleLabelUserList}"
                Grid.Row="0"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelSubitleStyle}"
                Text="{DynamicResource LabelUserList}"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"/>
            
            <Label
                Style="{StaticResource LabelSmallStyle}"
                Text="{DynamicResource LabelUsers}"
                x:Name="labelUsers"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Margin="0,0,0,50"
                Grid.Row="2"
                Grid.Column="1"/>

            <Grid
                ColumnDefinitions="3*,3*,1*,2*"
                Padding="0,0,0,10"
                Grid.Row="3"
                Grid.Column="1">
                
                <Label
                    Style="{StaticResource LabelSmallStyle}"
                    Text="{DynamicResource LabelUsername}"
                    Margin="22,0,0,0"
                    Grid.Column="0"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"/>

                <Label
                    Style="{StaticResource LabelSmallStyle}"
                    Text="{DynamicResource LabelEmail}"
                    Margin="8,0,0,0"
                    Grid.Column="1"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"/>

                <Label
                    Style="{StaticResource LabelSmallStyle}"
                    Text="{DynamicResource LabelRol}"
                    Margin="0,0,0,0"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"
                    Grid.Column="2"/>

                <Label
                    Style="{StaticResource LabelSmallStyle}"
                    Text="{DynamicResource LabelOptions}"
                    Margin="0,0,0,0"
                    VerticalOptions="Center"
                    HorizontalOptions="Start"
                    Grid.Column="3"/>
            </Grid>


            <CollectionView
                x:Name="UsersList"
                ItemsSource="{Binding}"
                SelectionMode="None"
                Grid.Row="4"
                Grid.Column="1">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame
                            CornerRadius="15"
                            BackgroundColor="{StaticResource Principal}"
                            HasShadow="True">

                            <Grid
                                ColumnDefinitions="3*,3*,1*,2*">

                                <Label
                                    Style="{StaticResource LabelSmallStyle}"
                                    Text="{Binding username}"
                                    Grid.Column="0"
                                    TextColor="{StaticResource White}"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>

                                <Label
                                    Style="{StaticResource LabelSmallStyle}"
                                    Text="{Binding email}"
                                    Grid.Column="1"
                                    TextColor="{StaticResource White}"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"/>

                                <Label
                                    Style="{StaticResource LabelSmallStyle}"
                                    Text="{Binding idRol}"
                                    TextColor="{StaticResource White}"
                                    Margin="16,0,0,0"
                                    VerticalOptions="Center"
                                    HorizontalOptions="Start"
                                    Grid.Column="2"/>

                                <Button
                                    Style="{StaticResource ButtonStyleIcon}"
                                    Clicked="GoToEdit"
                                    ImageSource="pencil_icon.png"
                                    Grid.Column="3"
                                    BackgroundColor="White"
                                    HorizontalOptions="Start"
                                    CommandParameter="{Binding}"/>

                                <Button
                                    Style="{StaticResource ButtonStyleIcon}"
                                    Clicked="BanUserClick"
                                    ImageSource="banned_icon.png"
                                    Grid.Column="3"
                                    BackgroundColor="White"
                                    HorizontalOptions="Center"
                                    CommandParameter="{Binding}"/>

                                <Button
                                    Style="{StaticResource ButtonStyleIcon}"
                                    Clicked="DeleteUserClick"
                                    ImageSource="bin_icon.png"
                                    Grid.Column="3"
                                    BackgroundColor="White"
                                    HorizontalOptions="End"
                                    CommandParameter="{Binding}" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
        </VerticalStackLayout> 
    </ScrollView>
</ContentPage>