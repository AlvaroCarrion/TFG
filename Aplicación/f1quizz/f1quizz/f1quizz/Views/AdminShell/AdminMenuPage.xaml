<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPQ.Views.AdminShell.AdminMenuPage"
             Title="AdminMenuPage">
    
    <Shell.TitleView>
        <StackLayout>
            <Label
                Style="{StaticResource LabelShellTitleStyle}"
                Text="{DynamicResource ShellLabelPolePositionQuiz}"/>
        </StackLayout>
    </Shell.TitleView>

    <VerticalStackLayout
        VerticalOptions="Fill">

        <Grid
            RowDefinitions="*,*,*,*,*,*"
            ColumnDefinitions="*,*,*">

            <Button
                Style="{StaticResource ButtonStyleIcon}"
                ImageSource="user_icon.png"
                Clicked="GoToAccount"
                Grid.Row="0"
                Grid.Column="2"/>

            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource TitleLabelAdministration}"
                Grid.Row="0"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelSubitleStyle}"
                Text="{DynamicResource LabelAdministrationMenu}"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="2"
                Grid.Column="1"/>

        </Grid>
        
        <Grid
            ColumnDefinitions="*,*,*,*"
            RowDefinitions="*,*,*,*,*">

            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource LabelWelcome}"
                x:Name="labelWelcome"
                Margin="0,0,0,30"
                HorizontalOptions="Center"
                Grid.ColumnSpan="2"
                FontSize="25"
                Grid.Row="0"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource LabelDBState}"
                Margin="0"
                HorizontalOptions="Start"
                FontSize="25"
                Grid.Row="1"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource LabelDBState}"
                x:Name="labelState"
                Margin="0"
                HorizontalOptions="End"
                FontSize="25"
                Grid.Row="1"
                Grid.Column="2"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Color="{DynamicResource Principal}"
                HeightRequest="1"
                Grid.ColumnSpan="2"
                Grid.Row="2"
                Grid.Column="1"/>

            <Button
                Style="{StaticResource ButtonStyle}"
                Text="{DynamicResource ButtonLabelManageUsers}"
                Clicked="GoToUserList"
                Grid.ColumnSpan="2"
                Grid.Row="3"
                Grid.Column="1"/>

        </Grid>
    </VerticalStackLayout>
</ContentPage>