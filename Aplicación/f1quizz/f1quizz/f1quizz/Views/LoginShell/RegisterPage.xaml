<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPQ.Views.LoginShell.RegisterPage"
             Title="RegisterPage">

    <Shell.TitleView>
        <StackLayout>
            <Label
                Style="{StaticResource LabelShellTitleStyle}"
                Text="{DynamicResource ShellLabelPolePositionQuiz}"/>
        </StackLayout>
    </Shell.TitleView>

    <VerticalStackLayout
        VerticalOptions="Fill">

        <Grid
            RowDefinitions="*,*,*,*,*,*,*,*,*,*,*,*,*,*,*,*"
            ColumnDefinitions="*,*,*">

            <HorizontalStackLayout
                HorizontalOptions="End"
                VerticalOptions="Start"
                Grid.Row="0"
                Grid.Column="2">

                <Picker
                    x:Name="languagePicker"
                    SelectedIndexChanged="LanguagePicker"
                    Style="{StaticResource PickerSytle}">
                </Picker>

                <Picker
                    x:Name="themePicker"
                    SelectedIndexChanged="ThemePicker"
                    Style="{StaticResource PickerSytle}"/>

            </HorizontalStackLayout>
            
            <Label
                Style="{StaticResource LabelTitleStyle}"
                Text="{DynamicResource TitleLabelRegister}"
                Grid.Row="0"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelSubitleStyle}"
                Text="{DynamicResource LabelCreateYourAccount}"
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="3"/>

            <Entry
                x:Name="mailEntry"
                TextChanged="OnEntryTextChanged"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelMail}"
                Grid.Row="2"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="3"
                Grid.Column="1"/>

            <Entry
                x:Name="usernameEntry"
                TextChanged="OnEntryTextChanged"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelUser}"
                Grid.Row="4"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="5"
                Grid.Column="1"/>

            <Entry
                x:Name="passwordEntry"
                TextChanged="OnEntryTextChanged"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelPassword}"
                IsPassword="True"
                Grid.Row="6"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="7"
                Grid.Column="1"/>

            <Entry
                x:Name="passwordEntry2"
                TextChanged="OnEntryTextChanged"
                Style="{StaticResource EntrySytle}"
                Placeholder="{DynamicResource EntryLabelConfirmPassword}"
                IsPassword="True"
                Grid.Row="8"
                Grid.Column="1"/>
            
            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="9"
                Grid.Column="1"/>

            <Button
                x:Name="registerButton"
                Clicked="registerButton_Clicked"
                IsEnabled="False"
                Opacity="0.5"
                Style="{StaticResource ButtonStyle}"
                Text="{DynamicResource ButtonLabelCreateAccount}"
                Grid.Row="10"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="11"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="12"
                Grid.Column="1"/>

            <Label
                Style="{StaticResource LabelRegularStyle}"
                Text="{DynamicResource LabelAlreadyHaveAccount}"
                Grid.Row="13"
                Grid.Column="1"/>

            <BoxView
                Style="{StaticResource BoxViewSytle}"
                Grid.Row="14"
                Grid.Column="1"/>

            <Button Style="{StaticResource ButtonStyle}"
                Text="{DynamicResource ButtonLabelGoToLogin}"
                Clicked="goToLogin"
                Grid.Row="15"
                Grid.Column="1"/>

        </Grid>
    </VerticalStackLayout>
</ContentPage>