<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPQ.Resources.Styles.MainStyles">

    <!-- Estilo para Label para Título del Shell -->
    <Style TargetType="Label" x:Key="LabelShellTitleStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="{DynamicResource Font911}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelShellTitleSize}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="Padding" Value="0, 10, 0, 10" />
    </Style>

    <!-- Estilo para Label para Título -->
    <Style TargetType="Label" x:Key="LabelTitleStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="{DynamicResource FontUnageo}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelTitleSize}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,50,0,50" />
    </Style>

    <!-- Estilo para Label para Subtítulo -->
    <Style TargetType="Label" x:Key="LabelSubitleStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Principal}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontF1Regular}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelRegularSize}" />
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="HorizontalOptions" Value="Fill"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,50" />
        <Setter Property="HeightRequest" Value="50" />
    </Style>

    <!-- Estilo para Label Regular -->
    <Style TargetType="Label" x:Key="LabelRegularStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="{DynamicResource FontF1Regular}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelRegularSize}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Estilo para Label Pequeño -->
    <Style TargetType="Label" x:Key="LabelSmallStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="{DynamicResource FontCreato}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelSmallSize}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <!-- Estilo para Label Circuito -->
    <Style TargetType="Label" x:Key="LabelCircuitStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorTheme }" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="{DynamicResource FontCreato}" />
        <Setter Property="FontSize" Value="{DynamicResource LabelRegularSize}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Estilo para Button Normal -->
    <Style TargetType="Button" x:Key="ButtonStyle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource Principal}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontUnageo}"/>
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="10,10"/>
        <Setter Property="MinimumHeightRequest" Value="50"/>
        <Setter Property="MaximumHeightRequest" Value="50"/>
        <Setter Property="MinimumWidthRequest" Value="400"/>
        <Setter Property="MaximumWidthRequest" Value="400"/>
    </Style>

    <!-- Estilo para Button Preguntas -->
    <Style TargetType="Button" x:Key="ButtonStyleQuestions">
        <Setter Property="TextColor" Value="{DynamicResource White}"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource ColorEntryText}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontUnageo}"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="10,10"/>
        <Setter Property="MinimumHeightRequest" Value="40"/>
        <Setter Property="MaximumHeightRequest" Value="40"/>
        <Setter Property="MinimumWidthRequest" Value="400"/>
        <Setter Property="MaximumWidthRequest" Value="400"/>
    </Style>

    <!-- Estilo para Button Perfil -->
    <Style TargetType="Button" x:Key="ButtonStyleIcon">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource Principal}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontUnageo}"/>
        <Setter Property="HorizontalOptions" Value="End"/>
        <Setter Property="VerticalOptions" Value="Start"/>
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="BorderWidth" Value="0"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="10,10"/>
        <Setter Property="Margin" Value="10,10"/>
        <Setter Property="MinimumHeightRequest" Value="50"/>
        <Setter Property="MaximumHeightRequest" Value="50"/>
        <Setter Property="MinimumWidthRequest" Value="50"/>
        <Setter Property="MaximumWidthRequest" Value="50"/>
    </Style>

    <!-- Estilo para Entry -->
    <Style TargetType="Entry" x:Key="EntrySytle">
        <Setter Property="TextColor" Value="{DynamicResource ColorTheme}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontUnageo}"/>
        <Setter Property="FontSize" Value="{DynamicResource LabelRegularSize}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource ColorEntryText}" />
        <Setter Property="MinimumHeightRequest" Value="50"/>
        <Setter Property="MaximumHeightRequest" Value="50"/>
        <Setter Property="MinimumWidthRequest" Value="400"/>
        <Setter Property="MaximumWidthRequest" Value="400"/>
    </Style>
    
    <!-- Estilo para Box View -->
    <Style TargetType="BoxView" x:Key="BoxViewSytle">
        <Setter Property="Color" Value="Transparent" />
        <Setter Property="Margin" Value="0,0,0,20" />
    </Style>

    <!-- Estilo para Picker -->
    <Style TargetType="Picker" x:Key="PickerSytle">
        <Setter Property="TextColor" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource Principal}" />
        <Setter Property="FontFamily" Value="{DynamicResource FontUnageo}"/>
        <Setter Property="FontSize" Value="{DynamicResource LabelSmallSize}" />
        <Setter Property="SelectedIndex" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="30"/>
        <Setter Property="MinimumWidthRequest" Value="120"/>
        <Setter Property="MaximumWidthRequest" Value="120"/>
    </Style>
    
    <!-- Estilo para CheckBox -->
    <Style TargetType="CheckBox" x:Key="CheckBoxStyle">
        <Setter Property="Color" Value="{DynamicResource ColorEntryText}" />
        <Setter Property="Background" Value="{DynamicResource ColorSecundary}" />
        <Setter Property="VerticalOptions" Value="Start"/>
        <Setter Property="MinimumHeightRequest" Value="20"/>
        <Setter Property="MinimumWidthRequest" Value="20"/>
    </Style>

    <!-- Estilo para Page -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BackgroundColor" Value="{DynamicResource ColorTheme}"/>
    </Style>

    <!-- Estilo para Shell -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource Principal}" />
        <Setter Property="Shell.ForegroundColor" Value="{AppThemeBinding Light={DynamicResource Black}, Dark={DynamicResource White}}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource ColorSecundary}"/>

        <Setter Property="Shell.FlyoutBackground">
            <RadialGradientBrush Center="0.5,0" Radius="1">
                <GradientStop Color="{DynamicResource Principal}" Offset="0.5" />
                <GradientStop Color="Transparent" Offset="1.0" />
            </RadialGradientBrush>
        </Setter>

        <Setter Property="Shell.DisabledColor" Value="{AppThemeBinding Light={DynamicResource Gray200}, Dark={DynamicResource Gray950}}" />
        <Setter Property="Shell.UnselectedColor" Value="{AppThemeBinding Light={DynamicResource Gray200}, Dark={DynamicResource Gray200}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{AppThemeBinding Light={DynamicResource White}, Dark={DynamicResource Black}}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{AppThemeBinding Light={DynamicResource Magenta}, Dark={DynamicResource White}}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{AppThemeBinding Light={DynamicResource Magenta}, Dark={DynamicResource White}}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={DynamicResource Gray900}, Dark={DynamicResource Gray200}}" />
    </Style>

</ResourceDictionary>