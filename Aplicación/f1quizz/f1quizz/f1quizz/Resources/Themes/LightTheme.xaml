<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PPQ.Resources.Themes.LightTheme">
    
    <!-- Colores Principales -->
    <Color x:Key="Principal">#FF1801</Color>
    <Color x:Key="ColorTheme">White</Color>
    <Color x:Key="ColorSecundary">#202020</Color>

    <!-- Colores Secundarios -->
    <Color x:Key="ColorWrongAns">#FF5C5C</Color>
    <Color x:Key="ColorCorrectAns">#07FF00</Color>
    <Color x:Key="ColorYellowSector">#FCFF05</Color>
    <Color x:Key="ColorPurpleSector">#E00073</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="ColorEntryBackground">#313131</Color>
    <Color x:Key="ColorEntryText">#A5A5A5</Color>
    <Color x:Key="White">White</Color>

    <!-- Tamaños de la Fuente-->
    <x:Int16 x:Key="LabelShellTitleSize">30</x:Int16>
    <x:Int16 x:Key="LabelTitleSize">40</x:Int16>
    <x:Int16 x:Key="LabelRegularSize">20</x:Int16>
    <x:Int16 x:Key="LabelSmallSize">15</x:Int16>

    <!-- Tipos de Fuente -->
    <x:String x:Key="FontF1">F1</x:String>
    <x:String x:Key="FontF1Regular">F1Regular</x:String>
    <x:String x:Key="FontUnageo">Unageo</x:String>
    <x:String x:Key="FontCreato">CreatoDisplay</x:String>
    <x:String x:Key="FontPresidency">Presidency</x:String>
    <x:String x:Key="Font911">911</x:String>
</ResourceDictionary>